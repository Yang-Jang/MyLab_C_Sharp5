@model FastFoodOnline.Web.Models.Food

@{
    // Nếu là Edit thì đổi Title thành "Cập nhật..."
    bool isEdit = ViewContext.RouteData.Values["action"].ToString() == "Edit";
    ViewData["Title"] = isEdit ? "Cập nhật món" : "Thêm món mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Kế thừa các biến CSS từ Index hoặc khai báo lại nếu cần */
    .sf-form-card {
        background: #fff;
        border: 1px solid rgba(17, 24, 39, .12);
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(17, 24, 39, .10);
        padding: 30px;
        max-width: 800px;
        margin: 0 auto;
    }

    .sf-label {
        font-weight: 900;
        font-size: 14px;
        color: #111827;
        margin-bottom: 8px;
        display: block;
    }

    .sf-input {
        height: 44px; /* Chuẩn auth.css */
        border-radius: 14px; /* Chuẩn profile.css */
        border: 1px solid rgba(17, 24, 39, .12);
        padding: 0 16px;
        width: 100%;
        transition: all 0.2s;
    }

    .sf-input:focus {
        border-color: #EE4D2D;
        box-shadow: 0 0 0 4px rgba(238, 77, 45, 0.1);
        outline: none;
    }

    textarea.sf-input {
        height: auto;
        padding: 12px 16px;
        min-height: 100px;
    }

    .btn-sf-submit {
        height: 44px;
        border-radius: 999px;
        background: linear-gradient(135deg, #EE4D2D, #FF7337);
        color: #fff;
        border: none;
        font-weight: 800;
        padding: 0 32px;
        box-shadow: 0 10px 18px rgba(238, 77, 45, .25);
        transition: transform 0.2s;
    }

    .btn-sf-submit:hover {
        transform: translateY(-2px);
    }

    .btn-sf-back {
        height: 44px;
        border-radius: 999px;
        background: #f3f4f6;
        color: #4b5563;
        border: none;
        font-weight: 800;
        padding: 0 24px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }
    .btn-sf-back:hover {
        background: #e5e7eb;
        color: #111827;
    }
</style>

<div class="container py-5">
    <div class="sf-form-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="m-0 fw-bolder text-dark">
                @(isEdit ? "Cập Nhật Món Ăn" : "Thêm Món Mới")
            </h2>
        </div>
        
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @if (isEdit)
            {
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CreatedAt" />
            }

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="sf-label">Tên Món Ăn</label>
                    <input asp-for="Name" class="sf-input" placeholder="Ví dụ: Gà rán giòn..." required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="sf-label">Giá Bán (VNĐ)</label>
                    <input asp-for="Price" type="number" class="sf-input" placeholder="0" required />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="sf-label">Mô Tả Chi Tiết</label>
                <textarea asp-for="Description" class="sf-input" placeholder="Thành phần, hương vị..."></textarea>
            </div>

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="ImageUrl" class="sf-label">Đường Dẫn Hình Ảnh</label>
                    <input asp-for="ImageUrl" class="sf-input" placeholder="/images/food.jpg" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="CategoryId" class="sf-label">ID Danh Mục</label>
                    <input asp-for="CategoryId" type="number" class="sf-input" required />
                </div>
            </div>

            @if (isEdit)
            {
                <div class="mb-4 form-check ps-4">
                    <input class="form-check-input" asp-for="IsActive" style="transform: scale(1.2);" />
                    <label class="form-check-label fw-bold ms-2 text-dark" asp-for="IsActive">
                        Đang kinh doanh (Active)
                    </label>
                </div>
            }

            <div class="d-flex gap-2 mt-4 pt-2 border-top">
                <button type="submit" class="btn-sf-submit">
                    <i class="fas fa-save me-2"></i> Lưu Thông Tin
                </button>
                <a asp-action="Index" class="btn-sf-back">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>