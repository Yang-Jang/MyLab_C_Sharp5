@model FastFoodOnline.Web.Models.Food

@{
    ViewData["Title"] = "Cập Nhật Món Ăn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Khai báo biến màu (Nếu layout chưa có) */
    :root {
        --sf-primary: #EE4D2D;
        --sf-primary-grad: linear-gradient(135deg, #EE4D2D, #FF7337);
        --sf-dark: #111827;
        --sf-border: rgba(17, 24, 39, .12);
    }

    /* Card chứa form */
    .sf-form-card {
        background: #fff;
        border: 1px solid var(--sf-border);
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(17, 24, 39, .10);
        padding: 30px;
        max-width: 800px;
        margin: 0 auto;
    }

    /* Label & Input */
    .sf-label {
        font-weight: 900;
        font-size: 14px;
        color: var(--sf-dark);
        margin-bottom: 8px;
        display: block;
    }

    .sf-input {
        height: 44px;
        border-radius: 14px;
        border: 1px solid var(--sf-border);
        padding: 0 16px;
        width: 100%;
        transition: all 0.2s;
        font-size: 15px;
    }

    .sf-input:focus {
        border-color: var(--sf-primary);
        box-shadow: 0 0 0 4px rgba(238, 77, 45, 0.1);
        outline: none;
    }

    textarea.sf-input {
        height: auto;
        padding: 12px 16px;
        min-height: 120px;
    }

    /* Checkbox Active */
    .sf-check-group {
        display: flex;
        align-items: center;
        background: #f9fafb;
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid var(--sf-border);
        cursor: pointer;
        transition: 0.2s;
    }

    .sf-check-group:hover {
        background: #fff5f2;
        border-color: rgba(238, 77, 45, 0.3);
    }

    .sf-check-input {
        width: 20px;
        height: 20px;
        accent-color: var(--sf-primary);
        margin-right: 10px;
        cursor: pointer;
    }

    /* Buttons */
    .btn-sf-submit {
        height: 44px;
        border-radius: 999px;
        background: var(--sf-primary-grad);
        color: #fff;
        border: none;
        font-weight: 800;
        padding: 0 32px;
        box-shadow: 0 10px 18px rgba(238, 77, 45, .25);
        transition: transform 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-sf-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 20px rgba(238, 77, 45, .35);
        color: #fff;
    }

    .btn-sf-back {
        height: 44px;
        border-radius: 999px;
        background: #f3f4f6;
        color: #4b5563;
        border: none;
        font-weight: 800;
        padding: 0 24px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: 0.2s;
    }
    .btn-sf-back:hover {
        background: #e5e7eb;
        color: var(--sf-dark);
    }
</style>

<div class="container py-5">
    <div class="sf-form-card">
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
            <h2 class="m-0 fw-bolder text-dark" style="font-size: 24px;">
                <i class="fas fa-edit me-2" style="color: var(--sf-primary)"></i>Cập Nhật Món Ăn
            </h2>
            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">ID: #@Model.Id</span>
        </div>
        
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3" role="alert"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label asp-for="Name" class="sf-label">Tên Món Ăn</label>
                    <input asp-for="Name" class="sf-input" placeholder="Ví dụ: Gà rán sốt cay..." required />
                    <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                </div>
                
                <div class="col-md-6 mb-4">
                    <label asp-for="Price" class="sf-label">Giá Bán (VNĐ)</label>
                    <div class="input-group">
                        <input asp-for="Price" type="number" class="sf-input" style="border-radius: 14px;" required />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small mt-1"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="sf-label">Mô Tả Chi Tiết</label>
                <textarea asp-for="Description" class="sf-input" placeholder="Mô tả thành phần, hương vị của món ăn..."></textarea>
                <span asp-validation-for="Description" class="text-danger small mt-1"></span>
            </div>

            <div class="row align-items-end">
                <div class="col-md-8 mb-4">
                    <label asp-for="ImageUrl" class="sf-label">Đường Dẫn Hình Ảnh</label>
                    <input asp-for="ImageUrl" class="sf-input" placeholder="https://..." onchange="document.getElementById('previewImg').src = this.value" />
                </div>
                
                <div class="col-md-4 mb-4">
                    <label asp-for="CategoryId" class="sf-label">ID Danh Mục</label>
                    <input asp-for="CategoryId" type="number" class="sf-input" required />
                    <small class="text-muted d-block mt-1">Nhập ID danh mục (VD: 1, 2)</small>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-8">
                    <label class="sf-label mb-2">Xem Trước Ảnh</label>
                    <img id="previewImg" src="@(Model.ImageUrl ?? "https://placehold.co/600x400?text=No+Image")" 
                         style="height: 100px; width: 100px; object-fit: cover; border-radius: 12px; border: 1px solid #eee;" 
                         onerror="this.src='https://placehold.co/100x100?text=Error'" />
                </div>
                
                <div class="col-md-4 d-flex align-items-end">
                    <label class="sf-check-group w-100">
                        <input class="sf-check-input" asp-for="IsActive" type="checkbox" />
                        <span class="fw-bold text-dark">Đang Kinh Doanh</span>
                    </label>
                </div>
            </div>

            <div class="d-flex gap-3 pt-3 border-top mt-2">
                <button type="submit" class="btn-sf-submit">
                    <i class="fas fa-save"></i> Lưu Thay Đổi
                </button>
                <a asp-action="Index" class="btn-sf-back">
                    <i class="fas fa-arrow-left me-2"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}