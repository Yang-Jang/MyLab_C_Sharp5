@model IEnumerable<FastFoodOnline.Web.Models.Food>

@{
    ViewData["Title"] = "Quản lý Thực đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --sf-primary: #EE4D2D;
        --sf-primary-grad: linear-gradient(135deg, #EE4D2D, #FF7337);
        --sf-dark: #111827;
        --sf-gray: #6b7280;
        --sf-bg-light: #f9fafb;
        --sf-border: rgba(17, 24, 39, .12);
        --sf-shadow: 0 10px 18px rgba(17, 24, 39, .06);
        --sf-shadow-hover: 0 16px 30px rgba(17, 24, 39, .10);
        --sf-radius-card: 18px;
        --sf-radius-pill: 999px;
    }

    body {
        background-color: var(--sf-bg-light);
        color: var(--sf-dark);
        font-family: 'Inter', system-ui, sans-serif;
    }

    /* Card Style */
    .sf-admin-card {
        background: #fff;
        border: 1px solid var(--sf-border);
        border-radius: var(--sf-radius-card);
        box-shadow: var(--sf-shadow);
        overflow: hidden;
        transition: all 0.2s ease;
    }

    .sf-admin-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--sf-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
    }

    .sf-admin-title {
        font-weight: 900;
        font-size: 1.25rem;
        color: var(--sf-dark);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* Table Style */
    .table-sf thead th {
        background-color: #f8f9fa;
        color: var(--sf-gray);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        border-bottom: 2px solid var(--sf-border);
        padding: 16px;
    }

    .table-sf tbody td {
        vertical-align: middle;
        padding: 16px;
        color: var(--sf-dark);
        border-bottom: 1px solid rgba(17, 24, 39, .05);
        font-size: 0.95rem;
    }

    .table-sf tbody tr:hover {
        background-color: #fff5f2; /* Màu cam rất nhạt khi hover */
    }

    /* Images */
    .sf-food-thumb {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        object-fit: cover;
        border: 1px solid rgba(0,0,0,0.05);
    }

    /* Buttons */
    .btn-sf-primary {
        background: var(--sf-primary-grad);
        color: #fff;
        border: none;
        border-radius: var(--sf-radius-pill);
        padding: 10px 24px;
        font-weight: 700;
        box-shadow: 0 4px 10px rgba(238, 77, 45, 0.2);
        transition: transform 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-sf-primary:hover {
        transform: translateY(-2px);
        color: #fff;
        box-shadow: 0 6px 15px rgba(238, 77, 45, 0.3);
    }

    .btn-action-icon {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .btn-edit { background: #eff6ff; color: #3b82f6; }
    .btn-edit:hover { background: #3b82f6; color: #fff; }

    .btn-delete { background: #fef2f2; color: #ef4444; }
    .btn-delete:hover { background: #ef4444; color: #fff; }

    /* Badges */
    .badge-sf {
        padding: 6px 12px;
        border-radius: var(--sf-radius-pill);
        font-weight: 800;
        font-size: 0.75rem;
    }
    .badge-active { background: rgba(34, 197, 94, 0.1); color: #16a34a; }
    .badge-inactive { background: rgba(107, 114, 128, 0.1); color: #4b5563; }
</style>

<div class="container py-4">
    <div class="sf-admin-card">
        <div class="sf-admin-header">
            <h1 class="sf-admin-title">
                <i class="fas fa-utensils" style="color: var(--sf-primary)"></i>
                Quản lý Thực đơn
            </h1>
            <a asp-action="Create" class="btn-sf-primary">
                <i class="fas fa-plus"></i> Thêm món mới
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-sf mb-0">
                <thead>
                    <tr>
                        <th>Món ăn</th>
                        <th>Danh mục (ID)</th>
                        <th>Giá bán</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@item.ImageUrl" class="sf-food-thumb" 
                                             onerror="this.src='https://placehold.co/56x56?text=IMG'" />
                                        <div>
                                            <div class="fw-bold text-dark">@item.Name</div>
                                            <small class="text-muted">ID: #@item.Id</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="fw-bold text-secondary">#@item.CategoryId</span>
                                </td>
                                <td class="fw-bolder" style="color: var(--sf-primary)">
                                    @item.Price.ToString("N0") ₫
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge-sf badge-active">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge-sf badge-inactive">Ngừng bán</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-icon btn-edit me-2" title="Sửa">
                                        <i class="fas fa-pen fa-sm"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-icon btn-delete" 
                                       title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa món @item.Name không?');">
                                        <i class="fas fa-trash fa-sm"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                                <p class="text-muted fw-bold">Chưa có dữ liệu món ăn</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>