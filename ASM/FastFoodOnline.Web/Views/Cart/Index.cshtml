@model FastFoodOnline.Web.Models.Cart
@{
    ViewData["Title"] = "Giỏ hàng";
    decimal total = Model?.Items?.Sum(i => i.Quantity * i.UnitPrice) ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

<div class="container sf-container">
    <div class="sf-cart-page">
        <div class="sf-page-head">
            <h1 class="sf-page-title">
                <i class="fa-solid fa-cart-shopping me-2"></i>Giỏ hàng
            </h1>
            <a class="btn sf-btn-ghost sf-btn-sm" asp-controller="Foods" asp-action="Index">
                <i class="fa-solid fa-utensils me-2"></i>Tiếp tục chọn món
            </a>
        </div>

        @if (Model == null || Model.Items == null || !Model.Items.Any())
        {
            <div class="sf-empty-card">
                <div class="sf-empty-ic"><i class="fa-solid fa-basket-shopping"></i></div>
                <div class="sf-empty-title">Giỏ hàng đang trống</div>
                <div class="sf-empty-sub">Hãy chọn thêm món ngon và quay lại thanh toán nhé.</div>
                <a class="btn sf-btn-primary sf-btn-lg mt-3" asp-controller="Foods" asp-action="Index">
                    <i class="fa-solid fa-magnifying-glass me-2"></i>Đi chọn món
                </a>
            </div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-12 col-lg-8">
                    <div class="sf-card">
                        <div class="sf-card-head">
                            <div class="sf-card-title">
                                <i class="fa-solid fa-bag-shopping me-2"></i>Sản phẩm trong giỏ
                            </div>
                        </div>

                        <div class="sf-card-body">
                            <div class="sf-cart-list">
                                @foreach (var item in Model.Items)
                                {
                                    var name = item.Food?.Name ?? item.Combo?.Name ?? "Món";
                                    var img = item.Food?.ImageUrl ?? item.Combo?.ImageUrl;
                                    var isCombo = item.ComboId != null;

                                    <div class="sf-cart-item">
                                        <div class="sf-item-left">
                                            <div class="sf-item-thumb">
                                                <img src="@img" alt="@name" loading="lazy" onerror="this.src='https://placehold.co/60x60?text=IMG'"/>
                                            </div>

                                            <div class="sf-item-info">
                                                <div class="sf-item-name" title="@name">@name</div>
                                                <div class="sf-item-meta">
                                                    @if (isCombo)
                                                    {
                                                        <span class="sf-tag"><i class="fa-solid fa-tags me-1"></i>Combo</span>
                                                    }
                                                    <span class="sf-muted">Đơn giá:</span>
                                                    <span class="sf-item-unit">@item.UnitPrice.ToString("N0") đ</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="sf-item-right">
                                            
                                            <form asp-action="UpdateQuantity" method="post" class="sf-qty-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="itemId" value="@item.Id" />

                                                <div class="sf-qty-stepper">
                                                    <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="sf-qty-btn">
                                                        <i class="fa-solid fa-minus"></i>
                                                    </button>

                                                    <input type="number" class="sf-qty-input" value="@item.Quantity" readonly />

                                                    <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="sf-qty-btn">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </button>
                                                </div>
                                            </form>

                                            <div class="sf-item-total">
                                                @((item.Quantity * item.UnitPrice).ToString("N0")) đ
                                            </div>

                                            <form asp-action="Remove" method="post" class="sf-remove-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="itemId" value="@item.Id" />
                                                <button type="submit" class="sf-remove-btn" title="Xoá">
                                                    <i class="fa-solid fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            <div class="mt-3 text-muted small">
                                <i class="fa-regular fa-lightbulb me-2"></i>
                                Bạn có thể tăng/giảm số lượng, hệ thống sẽ tự cập nhật giá tiền.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="sf-card sf-sticky">
                        <div class="sf-card-head">
                            <div class="sf-card-title">
                                <i class="fa-solid fa-receipt me-2"></i>Tóm tắt đơn hàng
                            </div>
                        </div>

                        <div class="sf-card-body">
                            <div class="sf-summary">
                                <div class="sf-summary-row">
                                    <span class="sf-muted">Tạm tính</span>
                                    <span class="fw-bold">@total.ToString("N0") đ</span>
                                </div>
                                <div class="sf-summary-row">
                                    <span class="sf-muted">Phí giao hàng</span>
                                    <span class="fw-bold">0 đ</span>
                                </div>

                                <div class="sf-summary-line"></div>

                                <div class="sf-summary-row sf-summary-total">
                                    <span>Tổng cộng</span>
                                    <span class="sf-total">@total.ToString("N0") đ</span>
                                </div>

                                <a asp-controller="Checkout" asp-action="Index" class="btn sf-btn-primary sf-btn-lg w-100 mt-3">
                                    <i class="fa-solid fa-credit-card me-2"></i>Thanh toán
                                </a>

                                <div class="sf-summary-note">
                                    Tip: Kiểm tra lại địa chỉ và số điện thoại ở bước thanh toán tiếp theo.
                                </div>
                                
                                <div class="text-center mt-2">
                                    <form asp-action="Clear" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link text-danger text-decoration-none btn-sm fw-bold" 
                                                onclick="return confirm('Xóa hết giỏ hàng?');">
                                            <i class="fa-solid fa-broom me-1"></i>Xóa tất cả
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>