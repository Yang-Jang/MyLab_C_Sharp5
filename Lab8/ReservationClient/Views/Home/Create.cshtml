@model ReservationClient.Models.Reservation
@{
    ViewData["Title"] = "Tạo mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card card-custom p-5">
                <div class="text-center mb-4">
                    <div class="bg-mint-light d-inline-block p-3 rounded-circle mb-3">
                        <i class="fa-solid fa-ticket fa-2x text-mint"></i>
                    </div>
                    <h3 class="fw-bold">Tạo vé mới</h3>
                    <p class="text-muted small">Điền thông tin chi tiết bên dưới</p>
                </div>

                <form asp-action="Create">
                    <div class="form-group mb-3">
                        <label class="form-label fw-bold small text-uppercase text-muted">Tên khách hàng</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="fa-regular fa-user text-mint"></i></span>
                            <input asp-for="Name" class="form-control border-start-0 ps-0" placeholder="Nhập tên..." />
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label fw-bold small text-uppercase text-muted">Điểm đi</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-map-pin text-mint"></i></span>
                                <input asp-for="StartLocation" class="form-control border-start-0 ps-0" placeholder="Hà Nội..." />
                            </div>
                        </div>
                        <div class="col-md-6 form-group mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Điểm đến</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-location-arrow text-mint"></i></span>
                                <input asp-for="EndLocation" class="form-control border-start-0 ps-0" placeholder="Đà Nẵng..." />
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary py-2">
                            <i class="fa-solid fa-check me-2"></i>Xác nhận
                        </button>
                        <a asp-action="Index" class="btn btn-light text-muted py-2">
                            Hủy bỏ
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>