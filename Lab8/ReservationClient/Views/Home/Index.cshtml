@model IEnumerable<ReservationClient.Models.Reservation>
@{
    ViewData["Title"] = "Danh sách đặt chỗ";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">Quản lý Đặt chỗ</h2>
            <p class="text-muted">Xem và quản lý lịch trình di chuyển</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Thêm mới
        </a>
    </div>

    <div class="card card-custom p-4">
        <div class="table-responsive">
            <table class="table table-custom table-hover align-middle">
                <thead>
                    <tr>
                        <th class="py-3 ps-3">ID</th>
                        <th class="py-3"><i class="fa-regular fa-user me-2"></i>Khách hàng</th>
                        <th class="py-3"><i class="fa-solid fa-location-dot me-2"></i>Điểm đi</th>
                        <th class="py-3"><i class="fa-solid fa-location-arrow me-2"></i>Điểm đến</th>
                        <th class="py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-mint">#@item.Id</td>
                            <td class="fw-bold">@item.Name</td>
                            <td><span class="badge bg-light text-dark border">@item.StartLocation</span></td>
                            <td><span class="badge bg-light text-dark border">@item.EndLocation</span></td>
                            <td class="text-center">
                                <a href="#" class="btn btn-sm btn-outline-warning me-1" title="Sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <a href="#" class="btn btn-sm btn-outline-danger" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="fa-solid fa-box-open fa-3x mb-3 text-mint"></i>
                    <p>Chưa có dữ liệu đặt chỗ nào.</p>
                </div>
            }
        </div>
    </div>
</div>